DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false

# Multimodal attachments
PAPERCLIP_MEDIA_WORKER_URL=http://media-worker:3200
PAPERCLIP_ATTACHMENT_MAX_BYTES=104857600
PAPERCLIP_VIDEO_MAX_BYTES=2147483648
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=paperclip-files

# Attachment size limits (bytes). Defaults: 100MB for files, 2GB for video.
# PAPERCLIP_ALLOWED_ATTACHMENT_TYPES=image/*,video/*,application/pdf
