    <mxCell id="sb" value="B — BUILD SEQUENCE (9 Phases · Each ships something real)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=13;fontStyle=1;fontFamily=Courier New;fontColor=#333333;" vertex="1" parent="1"><mxGeometry x="40" y="1279" width="800" height="18" as="geometry"/></mxCell>

    <!-- PHASE 0 -->
    <mxCell id="b0" value="PHASE 0 — DONE" style="swimlane;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;startSize=26;arcSize=4;" vertex="1" parent="1"><mxGeometry x="40" y="1307" width="1580" height="80" as="geometry"/></mxCell>
    <mxCell id="b0a" value="&lt;b&gt;✓ Paperclip Core running&lt;/b&gt; · Hetzner · Docker" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;arcSize=8;" vertex="1" parent="b0"><mxGeometry x="20" y="28" width="480" height="42" as="geometry"/></mxCell>
    <mxCell id="b0b" value="&lt;b&gt;✓ ERPNext + MCP connected&lt;/b&gt; · AccuBuild · MariaDB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;arcSize=8;" vertex="1" parent="b0"><mxGeometry x="520" y="28" width="480" height="42" as="geometry"/></mxCell>
    <mxCell id="b0c" value="&lt;b&gt;✓ All SRS + designs done&lt;/b&gt; · Permission SRS (18 tests) · ShipLog UI · Mentor arch · Build sequence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;arcSize=8;" vertex="1" parent="b0"><mxGeometry x="1020" y="28" width="540" height="42" as="geometry"/></mxCell>

    <!-- PHASE 1A -->
    <mxCell id="b1a" value="PHASE 1A — MONITORING · Prometheus + Grafana + Traefik + Portainer · Deploy Today" style="swimlane;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;fontSize=12;fontStyle=1;startSize=26;arcSize=4;fontColor=#1e40af;" vertex="1" parent="1"><mxGeometry x="40" y="1407" width="1580" height="100" as="geometry"/></mxCell>
    <mxCell id="b1aa" value="&lt;b&gt;Traefik v3 + Portainer&lt;/b&gt;&#xa;3-zone wildcard SSL via Cloudflare DNS-01&#xa;Eslam manages Docker via browser" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;fontSize=10;arcSize=8;" vertex="1" parent="b1a"><mxGeometry x="20" y="28" width="460" height="62" as="geometry"/></mxCell>
    <mxCell id="b1ab" value="&lt;b&gt;Prometheus + Grafana + cAdvisor + node-exporter&lt;/b&gt;&#xa;grafana.sanadai.com · Import: 1860, 893, 14282&#xa;Metrics: latency, tokens, errors, cost, model_calls" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;fontSize=10;arcSize=8;" vertex="1" parent="b1a"><mxGeometry x="500" y="28" width="560" height="62" as="geometry"/></mxCell>
    <mxCell id="b1ac" value="&lt;b&gt;Cloudflare 3-Zone DNS&lt;/b&gt;&#xa;*.sanadai.com 🟠 proxied (WAF+DDoS)&#xa;*.dev + *.sandbox ⚫ grey (Traefik SSL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#2563eb;fontSize=10;arcSize=8;" vertex="1" parent="b1a"><mxGeometry x="1080" y="28" width="480" height="62" as="geometry"/></mxCell>

    <!-- PHASE 1B -->
    <mxCell id="b1b" value="PHASE 1B — PENTAGI SECURITY · Same Day as 1A" style="swimlane;whiteSpace=wrap;html=1;fillColor=#f3e8ff;strokeColor=#7c3aed;fontSize=12;fontStyle=1;startSize=26;arcSize=4;fontColor=#4c1d95;" vertex="1" parent="1"><mxGeometry x="40" y="1527" width="1580" height="90" as="geometry"/></mxCell>
    <mxCell id="b1ba" value="&lt;b&gt;PentAGI as-is · MIT · docker compose up&lt;/b&gt;&#xa;Set ANTHROPIC_API_KEY · pentagi.sanadai.com&#xa;Scans: Sanad API, Paperclip, ERPNext, Hetzner ports, PG, Redis" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8ff;strokeColor=#7c3aed;fontSize=10;arcSize=8;" vertex="1" parent="b1b"><mxGeometry x="20" y="28" width="760" height="52" as="geometry"/></mxCell>
    <mxCell id="b1bb" value="&lt;b&gt;⚠ Safe usage:&lt;/b&gt; Run standalone · Connect via REST API only · Never fork · MIT as-is, AGPL if forked&#xa;Paperclip adapter → PentAGI REST API → Sanad analysis → ERPNext report" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3cd;strokeColor=#856404;fontSize=10;arcSize=8;" vertex="1" parent="b1b"><mxGeometry x="800" y="28" width="760" height="52" as="geometry"/></mxCell>

    <!-- PHASE 1C — EVALUATION ENGINE -->
    <mxCell id="b1c" value="PHASE 1C — EVALUATION ENGINE · SRS TO WRITE NEXT · DeepEval sidecar · Active Quality Gate" style="swimlane;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#6d28d9;fontSize=12;fontStyle=1;startSize=26;arcSize=4;fontColor=#4c1d95;" vertex="1" parent="1"><mxGeometry x="40" y="1637" width="1580" height="135" as="geometry"/></mxCell>
    <mxCell id="b1ca" value="&lt;b&gt;What it does&lt;/b&gt;&#xa;Developer changes prompt/model/skill/tool&#xa;→ Engine triggers automatically&#xa;→ Pulls baseline from PostgreSQL&#xa;→ Runs DeepEval sidecar (Docker REST)&#xa;→ Compares 5 dims before vs after&#xa;→ Verdict: promote or rollback" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#6d28d9;fontSize=10;arcSize=8;align=left;spacingLeft=6;verticalAlign=top;" vertex="1" parent="b1c"><mxGeometry x="20" y="32" width="380" height="93" as="geometry"/></mxCell>
    <mxCell id="b1cb" value="&lt;b&gt;5 Dimensions&lt;/b&gt;&#xa;1. Task Eval (tool, plan, output quality)&#xa;2. Skill Eval (rolling → skill_level → Qdrant)&#xa;3. Agent Eval (trust_score, failure patterns)&#xa;4. System Eval (p50/p95/p99 from Prometheus)&#xa;5. Model Comparison (score/cost → routing table)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#6d28d9;fontSize=10;arcSize=8;align=left;spacingLeft=6;verticalAlign=top;" vertex="1" parent="b1c"><mxGeometry x="420" y="32" width="440" height="93" as="geometry"/></mxCell>
    <mxCell id="b1cc" value="&lt;b&gt;Model Routing Table (auto-updated)&lt;/b&gt;&#xa;invoice_processing → GLM-4 (0.91, $0.02)&#xa;legal_contract → Claude (0.95, $0.10)&#xa;data_extraction → Gemini (0.89, $0.01)&#xa;→ LLM Router uses this table&#xa;→ Sanad auto-routes to cheapest model meeting quality threshold" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#6d28d9;fontSize=10;arcSize=8;align=left;spacingLeft=6;verticalAlign=top;" vertex="1" parent="b1c"><mxGeometry x="880" y="32" width="420" height="93" as="geometry"/></mxCell>
    <mxCell id="b1cd" value="&lt;b&gt;Mentor Integration&lt;/b&gt;&#xa;Eval Engine → skill_level delta&#xa;Eval Engine → trust_score&#xa;Mentor reads both&#xa;→ trainee to autonomous&#xa;→ coaching on regression" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#6d28d9;fontSize=10;arcSize=8;align=left;spacingLeft=6;verticalAlign=top;" vertex="1" parent="b1c"><mxGeometry x="1320" y="32" width="240" height="93" as="geometry"/></mxCell>

    <!-- PHASE 2 -->
    <mxCell id="b2" value="PHASE 2 — SAFETY CORE: Permissions + LLM Router (Built by humans · Governs all agents)" style="swimlane;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#d97706;fontSize=12;fontStyle=1;startSize=26;arcSize=4;" vertex="1" parent="1"><mxGeometry x="40" y="1792" width="1580" height="100" as="geometry"/></mxCell>
    <mxCell id="b2a" value="&lt;b&gt;Permission System (SOD)&lt;/b&gt;&#xa;SRS written → implement · migration 0038+0039&#xa;18 tests all green · 7 endpoints · 5-tab UI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#d97706;fontSize=10;arcSize=8;" vertex="1" parent="b2"><mxGeometry x="20" y="28" width="500" height="62" as="geometry"/></mxCell>
    <mxCell id="b2b" value="&lt;b&gt;LLM Router (FastAPI)&lt;/b&gt;&#xa;Claude · GPT-4 · Gemini · Ollama · GLM-4&#xa;Config per company + agent · Routing table from Eval Engine" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#d97706;fontSize=10;arcSize=8;" vertex="1" parent="b2"><mxGeometry x="540" y="28" width="500" height="62" as="geometry"/></mxCell>
    <mxCell id="b2c" value="&lt;b&gt;QA + Eval Pipeline on Every PR&lt;/b&gt;&#xa;L1 unit → L2 API → L3 Playwright · Eval Engine verdict&#xa;Human sees only: QA-passed + Eval-approved" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#6d28d9;fontSize=10;arcSize=8;" vertex="1" parent="b2"><mxGeometry x="1060" y="28" width="500" height="62" as="geometry"/></mxCell>

    <!-- PHASE 3 -->
    <mxCell id="b3" value="PHASE 3 — SANDBOX INFRASTRUCTURE (Isolated environments for agents and eval runs)" style="swimlane;whiteSpace=wrap;html=1;fillColor=#fde8e8;strokeColor=#dc2626;fontSize=12;fontStyle=1;startSize=26;arcSize=4;" vertex="1" parent="1"><mxGeometry x="40" y="1912" width="1580" height="90" as="geometry"/></mxCell>
    <mxCell id="b3a" value="&lt;b&gt;E2B → Microsandbox · Provisioner API&lt;/b&gt;&#xa;POST /sandbox/create → {internal_url, output_url}&#xa;Greenmask masks ERPNext · frappe_docker · Auto-TTL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fde8e8;strokeColor=#dc2626;fontSize=10;arcSize=8;" vertex="1" parent="b3"><mxGeometry x="20" y="28" width="760" height="52" as="geometry"/></mxCell>
    <mxCell id="b3b" value="&lt;b&gt;Dev Clone + 3-Zone URLs + Eval Baselines&lt;/b&gt;&#xa;eslam.dev.sanadai.com · output-001.sandbox.sanadai.com auto-created&#xa;Eval Engine stores baselines in PostgreSQL from dev clone runs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fde8e8;strokeColor=#dc2626;fontSize=10;arcSize=8;" vertex="1" parent="b3"><mxGeometry x="800" y="28" width="760" height="52" as="geometry"/></mxCell>

    <!-- PHASE 4 -->
    <mxCell id="b4" value="PHASE 4 — AGENTS BUILD SANAD · OpenHands + QA + Eval Engine All Active" style="swimlane;whiteSpace=wrap;html=1;fillColor=#e8fdf5;strokeColor=#059669;fontSize=12;fontStyle=1;startSize=26;arcSize=4;" vertex="1" parent="1"><mxGeometry x="40" y="2022" width="1580" height="90" as="geometry"/></mxCell>
    <mxCell id="b4a" value="&lt;b&gt;OpenHands builds ShipLog + Twin Agent + Mentor&lt;/b&gt;&#xa;Reads SRS → writes code → QA tests → Eval Engine judges → human reviews&#xa;SRS documents = agent task specifications" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8fdf5;strokeColor=#059669;fontSize=10;arcSize=8;" vertex="1" parent="b4"><mxGeometry x="20" y="28" width="760" height="52" as="geometry"/></mxCell>
    <mxCell id="b4b" value="&lt;b&gt;⚠ Rule: Agents never build the safety layer&lt;/b&gt;&#xa;Phase 2 (permissions + LLM Router) = humans only · Eval Engine = humans design, agents use&#xa;Everything after Phase 2 = agents can build it</mxCell>" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3cd;strokeColor=#856404;fontSize=10;arcSize=8;" vertex="1" parent="b4"><mxGeometry x="800" y="28" width="760" height="52" as="geometry"/></mxCell>

    <!-- PHASE 5 -->
    <mxCell id="b5" value="PHASE 5 — FULL PRODUCT · ShipLog + Twin + Mentor + Multi-Agent + Microsandbox" style="swimlane;whiteSpace=wrap;html=1;fillColor=#fde8f5;strokeColor=#be185d;fontSize=12;fontStyle=1;startSize=26;arcSize=4;" vertex="1" parent="1"><mxGeometry x="40" y="2132" width="1580" height="90" as="geometry"/></mxCell>
    <mxCell id="b5a" value="&lt;b&gt;ShipLog + Twin Agent + Mentor live&lt;/b&gt;&#xa;Mentor reads Eval Engine output · skill_level + trust_score&#xa;Graduation: trainee → autonomous when threshold met" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fde8f5;strokeColor=#be185d;fontSize=10;arcSize=8;" vertex="1" parent="b5"><mxGeometry x="20" y="28" width="760" height="52" as="geometry"/></mxCell>
    <mxCell id="b5b" value="&lt;b&gt;All 5 multi-agent patterns + Microsandbox on Hetzner&lt;/b&gt;&#xa;Maker→Checker · Parallel · Supervisor · Handoff · Escalation · All monitored + evaluated&#xa;Microsandbox replaces E2B: SDK swap = zero agent code change" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fde8f5;strokeColor=#be185d;fontSize=10;arcSize=8;" vertex="1" parent="b5"><mxGeometry x="800" y="28" width="760" height="52" as="geometry"/></mxCell>

    <!-- PHASE 6 -->
    <mxCell id="b6" value="PHASE 6 — FULL ERP + ALL COMPANIES (The complete vision on Hetzner)" style="swimlane;whiteSpace=wrap;html=1;fillColor=#fdeee8;strokeColor=#ea580c;fontSize=12;fontStyle=1;startSize=26;arcSize=4;" vertex="1" parent="1"><mxGeometry x="40" y="2242" width="1580" height="80" as="geometry"/></mxCell>
    <mxCell id="b6a" value="Odoo + SAP + Dynamics · Same MCP · Agents need zero code change · Company config selects ERP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdeee8;strokeColor=#ea580c;fontSize=10;arcSize=8;" vertex="1" parent="b6"><mxGeometry x="20" y="28" width="500" height="42" as="geometry"/></mxCell>
    <mxCell id="b6b" value="Accurate Systems · AccuBuild · Sales Force + more · CEO cross-company view" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdeee8;strokeColor=#ea580c;fontSize=10;arcSize=8;" vertex="1" parent="b6"><mxGeometry x="540" y="28" width="500" height="42" as="geometry"/></mxCell>
    <mxCell id="b6c" value="Every person: Twin+Mentor · Every action: MCP only · Every agent: sandboxed+monitored+evaluated · Any model: auto-routed by Eval Engine · On-premise · Arabic+English" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdeee8;strokeColor=#ea580c;fontSize=10;arcSize=8;" vertex="1" parent="b6"><mxGeometry x="1060" y="28" width="500" height="42" as="geometry"/></mxCell>

    <!-- PRINCIPLE -->
    <mxCell id="pr" value="See everything (Grafana) · Evaluate everything (Eval Engine) · Secure everything (PentAGI) · Isolate everything (Sandbox) · Agents propose, humans approve. Always. · Monitoring watches passively · Evaluation judges actively · Mentor graduates using Eval scores · The ERP is infrastructure. Sanad is the operating layer. The Evaluation Engine is the quality gate." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1814;strokeColor=#1a1814;fontSize=11;fontFamily=Arial;fontColor=#f7f4ef;arcSize=4;" vertex="1" parent="1"><mxGeometry x="40" y="2342" width="1580" height="40" as="geometry"/></mxCell>

  </root>
